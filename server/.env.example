# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dungeon_master

# Auth
JWT_SECRET=change-me-to-a-random-string

# Encryption key for API keys (32 hex bytes = 64 chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# SMTP (for email verification & password reset)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=no-reply@auth.dungeons-daggers.app
SMTP_FROM_NAME=Dungeons & Daggers
SMTP_REPLY_TO=support@dungeons-daggers.app
